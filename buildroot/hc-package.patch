diff --git a/package/hc/S60hc b/package/hc/S60hc
new file mode 100644
index 00000000..55a2a6a3
--- /dev/null
+++ b/package/hc/S60hc
@@ -0,0 +1,40 @@
+#!/bin/sh
+
+DAEMON=/usr/bin/hc
+PIDFILE=/var/run/hc.pid
+CONFIG=/etc/hc/hc-config.json
+
+start() {
+	printf "Starting hc: "
+	start-stop-daemon -S -q -m -p "$PIDFILE" -b -x "$DAEMON" -- \
+		serve -config "$CONFIG" -loglevel info
+	echo "OK"
+}
+
+stop() {
+	printf "Stopping hc: "
+	start-stop-daemon -K -q -p "$PIDFILE"
+	rm -f "$PIDFILE"
+	echo "OK"
+}
+
+restart() {
+	stop
+	start
+}
+
+case "$1" in
+	start)
+		start
+		;;
+	stop)
+		stop
+		;;
+	restart)
+		restart
+		;;
+	*)
+		echo "Usage: $0 {start|stop|restart}"
+		exit 1
+		;;
+esac
