diff --git a/package/hc/hc-db-init.sh.in b/package/hc/hc-db-init.sh.in
new file mode 100644
index 00000000..74e0af90
--- /dev/null
+++ b/package/hc/hc-db-init.sh.in
@@ -0,0 +1,21 @@
+#!/bin/sh
+
+schema_exists() {
+	echo -n "Checking database..."
+	res=1
+	psql -U postgres postgres -tAc "SELECT datname FROM pg_database where datname='@PGDATABASE@'" | grep -q @PGDATABASE@ && \
+	psql -U postgres @PGDATABASE@ -tAc \
+		"select 1 from information_schema.tables where table_name='tenants'" | grep -q 1 && res=0
+	return ${res}
+}
+
+if ! schema_exists; then
+	echo -ne "\nInitializing the new database..."
+	psql -U postgres postgres -c "CREATE ROLE @PGUSER@ LOGIN PASSWORD '@PGPASSWORD@'" &>/dev/null &&  echo -ne "\nCreating the new role (@PGUSER@)..."
+	psql -U postgres postgres -c "create database @PGDATABASE@" &>/dev/null &&  echo -ne "\nCreating new database (@PGDATABASE@)..."
+	psql -U postgres postgres -c "grant all privileges on database @PGDATABASE@ to @PGUSER@ " &>/dev/null && echo -ne "\nAssign permissions to database..."
+	psql -U postgres @PGDATABASE@ -f /usr/share/hc/schema.sql &>/dev/null && echo -ne "\nImporting schema..."
+	psql -U postgres @PGDATABASE@ -f /usr/share/hc/seed.sql &>/dev/null && echo -ne "\nInitializing tenants..."
+fi
+
+echo
diff --git a/package/hc/hc.mk b/package/hc/hc.mk
new file mode 100644
index 00000000..db503e12
--- /dev/null
+++ b/package/hc/hc.mk
@@ -0,0 +1,97 @@
+################################################################################
+#
+# hc
+#
+################################################################################
+
+HC_VERSION = 636215cc12c267fbe4342637a303eed71b7dc743
+HC_SITE = https://github.com/alessandrocarminati/hc.git
+HC_SITE_METHOD = git
+HC_LICENSE = GPL-3.0
+HC_LICENSE_FILES = LICENSE.md
+HC_DEPENDENCIES = postgresql host-openssl
+
+HC_GOMOD = hc
+HC_BUILD_TARGETS = .
+
+HC_CONF_DIR = $(TARGET_DIR)/etc/hc
+HC_CERT_FILE = /etc/hc/buildroot.crt
+HC_KEY_FILE = /etc/hc/buildroot.key
+HC_CONFIG_FILE = /etc/hc/hc-config.json
+
+define HC_INSTALL_DB_ASSETS
+	$(INSTALL) -d $(TARGET_DIR)/usr/share/hc
+	$(INSTALL) -m 0644  $(@D)/pg_schema.sql \
+		$(TARGET_DIR)/usr/share/hc/schema.sql
+	$(INSTALL) -m 0644 $(HC_PKGDIR)/seed.sql.in \
+		$(TARGET_DIR)/usr/share/hc/seed.sql
+	$(SED) 's#@TENANT_ID@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_DEFAULT_TENANT_ID))#g' \
+		$(TARGET_DIR)/usr/share/hc/seed.sql
+
+	$(INSTALL) -m 0755 $(HC_PKGDIR)/hc-db-init.sh.in \
+		$(TARGET_DIR)/usr/bin/hc-db-init.sh
+	$(SED) 's#@PGDATABASE@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_POSTGRES_DBNAME))#g' \
+		$(TARGET_DIR)/usr/bin/hc-db-init.sh
+	$(SED) 's#@PGUSER@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_POSTGRES_USER))#g' \
+		$(TARGET_DIR)/usr/bin/hc-db-init.sh
+	$(SED) 's#@PGPASSWORD@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_POSTGRES_PASSWORD))#g' \
+		$(TARGET_DIR)/usr/bin/hc-db-init.sh
+endef
+HC_POST_INSTALL_TARGET_HOOKS += HC_INSTALL_DB_ASSETS
+
+define HC_INSTALL_CONFIG
+	$(INSTALL) -d $(HC_CONF_DIR)
+
+	$(HOST_DIR)/bin/openssl req -x509 -nodes -newkey rsa:2048 \
+		-keyout $(HC_CONF_DIR)/buildroot.key \
+		-out $(HC_CONF_DIR)/buildroot.crt \
+		-days 3650 \
+		-subj "/CN=$(BR2_PACKAGE_HC_CFG_CERT_CN)"
+
+	chmod 0600 $(HC_CONF_DIR)/buildroot.key
+	chmod 0644 $(HC_CONF_DIR)/buildroot.crt
+
+	$(INSTALL) -m 0644 $(HC_PKGDIR)/hc-config.json.in \
+		$(HC_CONF_DIR)/hc-config.json
+	$(INSTALL) -m 0644 $(HC_PKGDIR)/hc-db-init.sh.in \
+		$(HC_CONF_DIR)/hc-db-init.sh
+
+
+
+	$(SED) 's#@INGEST_CLEAR_PORT@#$(BR2_PACKAGE_HC_CFG_INGEST_CLEAR_PORT)#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@INGEST_TLS_PORT@#$(BR2_PACKAGE_HC_CFG_INGEST_TLS_PORT)#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@HTTP_PORT@#$(BR2_PACKAGE_HC_CFG_HTTP_PORT)#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@HTTPS_PORT@#$(BR2_PACKAGE_HC_CFG_HTTPS_PORT)#g' \
+		$(HC_CONF_DIR)/hc-config.json
+
+	$(SED) 's#@PGHOST@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_POSTGRES_HOST))#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@PGPORT@#$(BR2_PACKAGE_HC_CFG_POSTGRES_PORT)#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@PGUSER@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_POSTGRES_USER))#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@PGPASSWORD@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_POSTGRES_PASSWORD))#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@PGDATABASE@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_POSTGRES_DBNAME))#g' \
+		$(HC_CONF_DIR)/hc-config.json
+
+	$(SED) 's#@TENANT_ID@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_DEFAULT_TENANT_ID))#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@TENANT_NAME@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_TENANT_NAME))#g' \
+		$(HC_CONF_DIR)/hc-config.json
+	$(SED) 's#@APIKEY_PEPPER@#$(call qstrip,$(BR2_PACKAGE_HC_CFG_APIKEY_PEPPER))#g' \
+		$(HC_CONF_DIR)/hc-config.json
+endef
+HC_POST_INSTALL_TARGET_HOOKS += HC_INSTALL_CONFIG
+
+define HC_INSTALL_INIT_SYSV
+	$(INSTALL) -D -m 0755 $(HC_PKGDIR)/S60hc \
+		$(TARGET_DIR)/etc/init.d/S60hc
+	$(INSTALL) -D -m 0755 $(HC_PKGDIR)/S59hc-init \
+		$(TARGET_DIR)/etc/init.d/S59hc-init
+endef
+
+$(eval $(golang-package))
